<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- ═══════════════════════════════════════════
         Identyfikacja projektu
         ═══════════════════════════════════════════ -->
    <groupId>org.dawciobiel.uigcli</groupId>
    <artifactId>shelldialog</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>user-interface-generator-cli</name>
    <description>CLI User Interface Generator using JLine 3</description>

    <!-- ═══════════════════════════════════════════
         Właściwości globalne
         ═══════════════════════════════════════════ -->
    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Wersje zależności -->
        <jline.version>3.30.4</jline.version>
    </properties>

    <!-- ═══════════════════════════════════════════
         Zależności
         ═══════════════════════════════════════════ -->
    <dependencies>

        <!-- JLine – terminal (rdzeń, wymagany zawsze) -->
        <dependency>
            <groupId>org.jline</groupId>
            <artifactId>jline-terminal</artifactId>
            <version>${jline.version}</version>
        </dependency>

        <!-- JLine – obsługa klawiatury, historia, autouzupełnianie -->
        <dependency>
            <groupId>org.jline</groupId>
            <artifactId>jline-reader</artifactId>
            <version>${jline.version}</version>
        </dependency>

        <!-- JLine – style i kolory (ANSI) -->
        <dependency>
            <groupId>org.jline</groupId>
            <artifactId>jline-style</artifactId>
            <version>${jline.version}</version>
        </dependency>

        <!-- JLine – Jansi: obsługa ANSI na Windows (cmd.exe, PowerShell) -->
        <dependency>
            <groupId>org.jline</groupId>
            <artifactId>jline-terminal-jansi</artifactId>
            <version>${jline.version}</version>
        </dependency>

        <dependency>
            <groupId>org.fusesource.jansi</groupId>
            <artifactId>jansi</artifactId>
            <version>2.4.2</version>
        </dependency>

        <!-- JLine – JNA: alternatywny backend natywny (opcjonalny, lepszy na niektórych systemach) -->
        <dependency>
            <groupId>org.jline</groupId>
            <artifactId>jline-terminal-jna</artifactId>
            <version>${jline.version}</version>
        </dependency>

    </dependencies>

    <!-- ═══════════════════════════════════════════
         Konfiguracja budowania
         ═══════════════════════════════════════════ -->
    <build>
        <plugins>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <forkCount>1</forkCount>
                    <reuseForks>false</reuseForks>
                </configuration>
            </plugin>

            <!-- Kompilator Java -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <encoding>UTF-8</encoding>
                </configuration>
            </plugin>

            <!-- Tworzenie wykonywalnego JAR (fat jar) z wszystkimi zależnościami -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <!-- Pakiety i nazwa klasy głównej -->
                                    <mainClass>org.dawciobiel.uigcli.Example</mainClass>
                                </transformer>
                            </transformers>
                            <!-- Nazwa wynikowego JAR -->
                            <finalName>${project.artifactId}-${project.version}</finalName>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Uruchamianie projektu: mvn exec:java -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.4.1</version>
                <configuration>
                    <!-- Pakiety i nazwa klasy głównej -->
                    <mainClass>org.dawciobiel.uigcli.Example</mainClass>
                    <quietLogs>true</quietLogs>
                    <cleanupDaemonThreads>false</cleanupDaemonThreads>
                </configuration>
            </plugin>

        </plugins>
    </build>

</project>